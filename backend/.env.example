# Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB Atlas Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/nn_billing?retryWrites=true&w=majority

# Security Keys
JWT_SECRET=generate_a_strong_random_secret_here
JWT_EXPIRE=30d

# CORS Configuration (Set to frontend URL in production, or * for mobile app)
FRONTEND_URL=*
